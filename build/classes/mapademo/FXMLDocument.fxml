<GridPane fx:id="gridBase" minHeight="700.0" minWidth="900.0" prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.FXMLDocumentController">
   <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
   </columnConstraints>
   <rowConstraints>
      <RowConstraints maxHeight="70.0" minHeight="10.0" prefHeight="70.0" vgrow="NEVER" />
      <RowConstraints maxHeight="5.0" minHeight="10.0" prefHeight="5.0" vgrow="SOMETIMES" />
      <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
   </rowConstraints>
   <children>
      <BorderPane minHeight="623.0" minWidth="900.0" prefHeight="623.0" prefWidth="900.0" GridPane.rowIndex="2">
         <center>
            <VBox prefHeight="556.0" prefWidth="853.0" stylesheets="@../resources/estilos.css">
               <children>
                  <SplitPane fx:id="splitPane" dividerPositions="0.19699727024567792" VBox.vgrow="ALWAYS">
                     <items>
                        <HBox maxWidth="350.0" minWidth="350.0" prefHeight="543.0" prefWidth="350.0">
                           <children>
                              <ListView fx:id="activityList" maxWidth="174.0" minWidth="175.0" onMouseClicked="#activitySelected" prefHeight="552.0" prefWidth="175.0" />
                              <ListView fx:id="map_listview" maxWidth="174.0" minWidth="175.0" onMouseClicked="#listClicked" prefHeight="399.0" prefWidth="175.0" />
                           </children>
                        </HBox>
                        <ScrollPane fx:id="map_scrollpane" hbarPolicy="ALWAYS" onMouseMoved="#showPosition" pannable="true" prefHeight="398.0" prefWidth="358.0" vbarPolicy="ALWAYS">
                           <content>
                              <Pane>
                                 <children>
                                    <ImageView pickOnBounds="true">
                                       <image>
                                          <Image url="@../../maps/upv.jpg" />
                                       </image>
                                    </ImageView>
                                 </children>
                              </Pane>
                           </content>
                        </ScrollPane>
                     </items>
                  </SplitPane>
               </children>
            </VBox>
         </center>
         <top>
            <HBox alignment="CENTER_RIGHT" fillHeight="false" maxHeight="27.0" minHeight="27.0" minWidth="888.0" prefHeight="27.0" prefWidth="888.0" spacing="5.0" BorderPane.alignment="CENTER">
               <children>
                  <MenuBar>
                    <menus>
                      <Menu mnemonicParsing="false" text="Ayuda">
                        <items>
                          <MenuItem mnemonicParsing="false" onAction="#about" text="Acerca de" />
                        </items>
                      </Menu>
                    </menus>
                  </MenuBar>
                  <Button mnemonicParsing="false" onAction="#cambiarMapa" text="Cambiar mapa" />
                  <Button mnemonicParsing="false" onAction="#importarGPX" text="Importar Carrera" />
                  <Button mnemonicParsing="false" onAction="#verActividades" text="Ver Actividades" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label text="Zoom" />
                  <Button mnemonicParsing="false" onAction="#zoomOut" text="-" />
                  <Slider fx:id="zoom_slider" HBox.hgrow="SOMETIMES" />
                  <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#zoomIn" text="+" />
               </children>
               <BorderPane.margin>
                  <Insets bottom="6.0" left="6.0" right="6.0" top="6.0" />
               </BorderPane.margin>
            </HBox>
         </top>
         <bottom>
            <HBox alignment="CENTER_RIGHT" maxHeight="27.0" minHeight="27.0" prefHeight="27.0" spacing="10.0" BorderPane.alignment="CENTER">
               <children>
                  <Button mnemonicParsing="false" onAction="#renameActivity" text="Renombrar Actividad" />
                  <Button mnemonicParsing="false" onAction="#removeActivity" text="Borrar Actividad" />
                  <Separator orientation="VERTICAL" prefHeight="200.0" />
                  <Button mnemonicParsing="false" onAction="#renameNote" text="Renombrar Anotación" />
                  <Button mnemonicParsing="false" onAction="#removeNote" text="Borrar Anotación" />
                  <Separator orientation="VERTICAL" prefHeight="200.0">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin></Separator>
                  <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Separator orientation="VERTICAL" prefHeight="200.0">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </Separator>
                  <Label fx:id="mousePosition" minHeight="-Infinity" minWidth="-Infinity" text="SceneX:     ScenY:     " wrapText="true" HBox.hgrow="ALWAYS" />
               </children>
               <BorderPane.margin>
                  <Insets bottom="6.0" left="6.0" right="6.0" top="6.0" />
               </BorderPane.margin>
            </HBox>
         </bottom>
      </BorderPane>
      <Separator prefWidth="200.0" GridPane.rowIndex="1" />
      <HBox alignment="CENTER" maxHeight="70.0" minHeight="70.0" prefHeight="70.0" prefWidth="900.0" spacing="10.0" GridPane.halignment="RIGHT" GridPane.vgrow="NEVER">
         <GridPane.margin>
            <Insets right="5.0" />
         </GridPane.margin>
         <children>
            <Button mnemonicParsing="false" onAction="#logOut" text="Log Out" />
            <Button mnemonicParsing="false" onAction="#logOutExit" text="Log Out &amp; Exit" />
            <Button mnemonicParsing="false" onAction="#modPerfil" text="Modificar Perfil">
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </Button>
            <Separator orientation="VERTICAL" prefHeight="200.0" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Separator orientation="VERTICAL" prefHeight="200.0">
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </Separator>
            <Label fx:id="username" text="Username">
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </Label>
            <ImageView fx:id="userAvatar" fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../resources/avatar_default.png" />
               </image>
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </ImageView>
         </children>
      </HBox>
   </children>
</GridPane>
