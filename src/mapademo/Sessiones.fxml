<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.SessionesController">
   <children>
      <VBox alignment="CENTER" layoutX="236.0" layoutY="45.0" prefHeight="600.0" prefWidth="600.0" spacing="10.0" styleClass="panel-fondo" stylesheets="@../resources/estilos.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox alignment="CENTER" minHeight="100.0" prefHeight="100.0" prefWidth="200.0" styleClass="header">
               <children>
                  <Label styleClass="titulo-destacado" text="Historial de sesiones" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="31.0" />
                     </font></Label>
               </children>
            </HBox>
            <TableView fx:id="tablaSesiones" prefHeight="300.0" prefWidth="580.0">
              <columns>
                <TableColumn fx:id="sesion" prefWidth="200.0" text="Sesión" />
                <TableColumn fx:id="time" prefWidth="95.0" text="Duración" />
                  <TableColumn fx:id="numImport" prefWidth="95.0" text="Actividades &#10;importadas" />
                  <TableColumn fx:id="numVista" prefWidth="95.0" text="Actividades&#10; vistas" />
                  <TableColumn fx:id="numNote" prefWidth="95.0" text="Anotaciones &#10;creadas" />
              </columns>
               <VBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </TableView>
            <HBox alignment="CENTER" prefWidth="600.0">
               <children>
                  <Label styleClass="texto-importante" stylesheets="@../resources/estilos.css" text="Totales acumulados" />
               </children>
            </HBox>
            <TableView fx:id="tablaTotal" minHeight="60.0" prefHeight="60.0" prefWidth="580.0">
              <columns>
                <TableColumn fx:id="totalTime" prefWidth="116.0" text="Duración" />
                <TableColumn fx:id="totalImport" prefWidth="174.0" text="Actividades importadas" />
                  <TableColumn fx:id="totalVista" prefWidth="138.0" text="Actividades vistas" />
                  <TableColumn fx:id="totalNote" prefWidth="152.0" text="Anotaciones creadas" />
              </columns>
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
               </VBox.margin>
            </TableView>
            <HBox alignment="CENTER_RIGHT">
               <children>
                  <Button mnemonicParsing="false" onAction="#volver" styleClass="boton-principal-neg" stylesheets="@../resources/estilos.css" text="Volver" />
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
